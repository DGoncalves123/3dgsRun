# ============================================================
# 3D Gaussian Splatting Pipeline Configuration
# ============================================================

# -- Frame Extraction (FFmpeg) --
# Frames per second to extract from video.
# Higher values give the smart selector more candidates to work with.
# 5 fps for a 3-minute video yields ~900 candidate frames before selection.
EXTRACT_FPS=5

# JPEG quality for extracted frames (2 = high quality, 31 = low)
JPEG_QUALITY=2

# -- Smart Frame Selection --
# Cosine similarity threshold for HSV histograms (0.0–1.0).
# Frames with similarity ABOVE this value are treated as the same viewpoint.
# Higher = stricter deduplication (fewer frames kept).
# Lower = more frames kept (more viewpoints, but more near-duplicates).
# 0.92 works well for slow walkthrough videos with a mostly static subject.
FRAME_SELECT_THRESHOLD=0.92

# -- COLMAP (Camera Pose Estimation) --
# Matcher type: "exhaustive" (best quality) or "sequential" (faster for long videos 500+ frames)
COLMAP_MATCHER="exhaustive"

# Camera model: OPENCV recommended for most cameras/phones
COLMAP_CAMERA_MODEL="OPENCV"

# Use single camera (1 = yes). Set to 1 since all frames come from one video.
COLMAP_SINGLE_CAMERA=1

# GPU index for COLMAP (-1 = auto)
COLMAP_GPU_INDEX=-1

# -- 3DGS Training --
# Number of training iterations (30000 = full quality, 7000 = quick preview)
TRAIN_ITERATIONS=30000

# Image resolution factor: 1=full, 2=half, 4=quarter
# For 10GB VRAM, use 2 (half resolution). Use 4 if OOM occurs.
TRAIN_RESOLUTION=2

# Densification gradient threshold (default 0.0002; increase to 0.0004 if OOM)
TRAIN_DENSIFY_GRAD_THRESHOLD=0.0002

# Test set split: every Nth image is held out for evaluation (0 = no test split)
TRAIN_TEST_INTERVAL=8

# -- .ksplat Conversion --
# Compression level: 0=none, 1=16-bit quantization (recommended), 2=max compression
KSPLAT_COMPRESSION=1

# -- Paths (auto-configured by setup.sh, override if needed) --
TOOLS_DIR="./tools"
GAUSSIAN_SPLATTING_DIR="./tools/gaussian-splatting"
GAUSSIAN_SPLATS_3D_DIR="./tools/gaussian-splats-3d"
DATA_DIR="./data"
